<?xml version="1.0" encoding="utf-8"?>
<!--
  접근성 서비스 수집 범위 (FEAT-01, v3.1 안정화 경량화).

  - accessibilityEventTypes: 화면 전환·내용 변경 2종만 수신
      typeWindowStateChanged   : 창/Activity 전환
      typeWindowContentChanged : 화면 내용 변경 (서비스에서 700ms throttle)
      ※ typeViewTextChanged 제거 — 콜백 폭주·배터리 소모 주범, state/content로 충분
  - accessibilityFlags:
      flagReportViewIds : viewIdResourceName 수집 가능
      ※ flagIncludeNotImportantViews 제거 — 빈 컨테이너까지 순회해 노드 폭증/부하
      ※ flagRetrieveInteractiveWindows 제거 — system_server 부하·프리즈 위험
  - canRetrieveWindowContent="true" : 노드 트리(화면 내용) 조회 허용
  - packageNames="com.woowahan.bros" : 배민커넥트만 대상 (노이즈/부하 감소)
  - notificationTimeout="300" : 이벤트 콜백 throttle(ms) — 100→300 상향
-->
<accessibility-service xmlns:android="http://schemas.android.com/apk/res/android"
    android:accessibilityEventTypes="typeWindowStateChanged|typeWindowContentChanged"
    android:accessibilityFeedbackType="feedbackGeneric"
    android:accessibilityFlags="flagReportViewIds"
    android:canRetrieveWindowContent="true"
    android:notificationTimeout="300"
    android:packageNames="com.woowahan.bros"
    android:description="@string/accessibility_service_desc" />
