<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- 모드 A 섹션 : 저장된 메모 선택 → 팝업 직접 표시 -->
        <TextView
            android:id="@+id/tvSectionA"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/test_section_a"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/spinnerMemos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/btnShowSelected"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/btn_show_selected" />

        <!-- 구분선 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp"
            android:background="#DDDDDD" />

        <!-- 모드 B 섹션 : 붙여넣기 텍스트 → 추출→매칭→팝업 파이프라인 검증 -->
        <TextView
            android:id="@+id/tvSectionB"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/test_section_b"
            android:textSize="16sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etTestText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="top"
            android:hint="@string/hint_test_text"
            android:inputType="textMultiLine"
            android:lines="4"
            android:background="@android:drawable/edit_text"
            android:textColor="@color/black"
            android:textColorHint="#888888"
            android:padding="12dp" />

        <Button
            android:id="@+id/btnMatchTest"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/btn_match_test" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp"
            android:background="#DDDDDD" />

        <TextView
            android:id="@+id/tvSectionC"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/test_section_c"
            android:textSize="16sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etPickup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@android:drawable/edit_text"
            android:hint="@string/hint_pickup"
            android:inputType="text"
            android:padding="12dp"
            android:textColor="@color/black"
            android:textColorHint="#888888" />

        <EditText
            android:id="@+id/etDest"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@android:drawable/edit_text"
            android:hint="@string/hint_dest"
            android:inputType="text"
            android:padding="12dp"
            android:textColor="@color/black"
            android:textColorHint="#888888" />

        <Button
            android:id="@+id/btnRouteTest"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/btn_route_test" />

    </LinearLayout>

</ScrollView>
